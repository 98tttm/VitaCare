# Sao chép thành file `.env` và điền giá trị thật (không commit `.env`).

# URL trang my-user — OAuth redirect; VitaBot cũng dùng để tạo link đầy đủ (/store-system, /policy/..., /blog) trong prompt.
FRONTEND_URL=http://localhost:4200

# --- Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID loại Web) ---
# Authorized redirect URI phải khớp CHÍNH XÁC với dòng OAUTH_GOOGLE_REDIRECT_URI bên dưới.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Facebook Login (Meta for Developers → App → Facebook Login → Settings) ---
# Valid OAuth Redirect URIs phải khớp CHÍNH XÁC với OAUTH_FACEBOOK_REDIRECT_URI.
OAUTH_FACEBOOK_APP_ID=
OAUTH_FACEBOOK_APP_SECRET=
OAUTH_FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# Cổng backend (mặc định 3000). Redirect URI trong Google/Facebook phải dùng cùng host:port.
# PORT=3000

# --- VitaBot (chat widget my-user) — Replicate (ưu tiên) hoặc Gemini (dự phòng) ---
# Token: https://replicate.com/account/api-tokens
# Model: dạng owner/model — mặc định Qwen3 instruct (Replicate)
REPLICATE_API_TOKEN=
REPLICATE_MODEL=qwen/qwen3-235b-a22b-instruct-2507
# REPLICATE_MAX_TOKENS=2048
# REPLICATE_TEMPERATURE=0.7
# REPLICATE_TOP_P=0.8
# Thời gian chờ sync (1–60s, giới hạn API Replicate)
# REPLICATE_WAIT_SECONDS=60
# Poll thêm khi model chưa xong (ms, mặc định 5 phút)
# REPLICATE_POLL_TIMEOUT_MS=300000
# Giới hạn độ dài prompt gửi Replicate (ký tự)
# REPLICATE_MAX_PROMPT_CHARS=100000

# Dự phòng Google AI (nếu không dùng Replicate hoặc Replicate lỗi)
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.0-flash

# Vài dòng bổ sung trong .env (tuỳ chọn; nếu cần văn dài hơn dùng file bên dưới)
# VITABOT_EXTRA_CONTEXT=

# File Markdown tùy chỉnh (ưu tiên hơn default). Mặc định: backend/data/vitabot-knowledge.md
# VITABOT_CONTEXT_FILE=/absolute/path/to/vitabot-knowledge.md
